REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key
# AI (debris analysis, crew suggestions, briefs) — https://console.groq.com
REACT_APP_GROQ_API_KEY=your-groq-api-key
# Optional: when COCO-SSD finds no boxes, Gemini can read the photo for scale/wildlife — https://aistudio.google.com/apikey
# REACT_APP_GEMINI_API_KEY=
# REACT_APP_GEMINI_VISION_MODEL=gemini-2.0-flash
# Optional: local YOLO server (better recall than in-browser COCO-SSD on some photos). Run: cd cv-server && pip install -r requirements.txt && python server.py
# REACT_APP_CV_SERVER_URL=http://127.0.0.1:8765
# Optional: Roboflow Infer (trained marine/TACO model). Base URL from Roboflow Deploy page (no ?api_key in the string).
# REACT_APP_ROBOFLOW_DETECT_URL=https://detect.roboflow.com/your-workspace/your-project/1
# REACT_APP_ROBOFLOW_API_KEY=
# Preferred (secure): local backend proxy (no key in browser). Start: npm run start:api
# REACT_APP_ROBOFLOW_PROXY_URL=http://localhost:8787
# Optional: text model (default llama-3.1-8b-instant — lighter TPD than llama-3.3-70b-versatile)
# REACT_APP_GROQ_TEXT_MODEL=llama-3.3-70b-versatile
